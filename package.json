{
  "name": "tv-broadcast",
  "version": "1.0.0",
  "description": "Steve's broadcast client",
  "main": "electron-main.js",
  "author": "Steve Ou",
  "license": "MIT",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node index.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "build:cli": "node scripts/build-cli.js",
    "build:cli:macos": "pkg index.js --output dist/cli/tv-broadcast-macos --target node18-macos-x64",
    "build:cli:linux": "pkg index.js --output dist/cli/tv-broadcast-linux --target node18-linux-x64",
    "build:cli:win": "pkg index.js --output dist/cli/tv-broadcast-win.exe --target node18-win-x64"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "hls.js": "^1.6.15",
    "inquirer": "8.2.6",
    "m3u8-parser": "^7.1.0",
    "upnp-mediarenderer-client": "^1.4.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "electron": "^39.2.3",
    "electron-builder": "^25.0.0",
    "pkg": "5.8.1"
  },
  "bin": {
    "tv-broadcast": "./index.js"
  },
  "build": {
    "appId": "com.steveou.tvbroadcast",
    "productName": "TV Broadcast",
    "files": [
      "index.html",
      "electron-main.js",
      "preload.js",
      "renderer.js",
      "component/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.video"
    }
  },
  "pkg": {
    "scripts": [
      "component/**/*.js"
    ],
    "assets": [
      "node_modules/m3u8-parser/dist/**/*"
    ],
    "targets": [
      "node18-macos-x64",
      "node18-linux-x64",
      "node18-win-x64"
    ]
  }
}
